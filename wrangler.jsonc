{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "auraaa",
  "compatibility_date": "2026-06-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "bun run build"
  }
}
